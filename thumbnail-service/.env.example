# Thumbnail Service Environment Variables

# Server Configuration
PORT=3001
NODE_ENV=development

# FFmpeg Paths (auto-detected in Docker)
FFMPEG_PATH=/usr/bin/ffmpeg
FFPROBE_PATH=/usr/bin/ffprobe

# API Key for authenticating requests from edge functions
# Set this to a strong random string and use the same value as THUMBNAIL_SERVICE_KEY in Supabase secrets
API_KEY=

# Rate limiting
RATE_LIMIT_WINDOW_MS=900000
RATE_LIMIT_MAX_REQUESTS=100
